{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony AI",
  "version": "0.1.4",
  "identifier": "ai.toad.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Symphony AI",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "decorations": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://api.github.com https://github.com; img-src 'self' data: https://*.githubusercontent.com; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI software foundry and agent workspace.",
    "longDescription": "Symphony AI turns project ideas into durable specs, launches role-based coding-agent teams, tracks real git work, monitors drift, and gates risky changes through a local-first desktop workspace.",
    "resources": {
      "../../scripts": "engine/scripts",
      "../../src": "engine/src",
      "../../package.json": "engine/package.json",
      "../../node_modules/@lydell/node-pty": "engine/node_modules/@lydell/node-pty",
      "../../node_modules/@lydell/node-pty-win32-x64": "engine/node_modules/@lydell/node-pty-win32-x64"
    },
    "externalBin": [],
    "copyright": "Copyright (c) 2026",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2NzJEREFBMDRGQjY5OQpSV1NadGsrZzJpMW5CMDA3WFF4bjVPbFkzQVRUM1d2NHdGZmtobFlCNGxBODN2MzFRa0tBSG5yQQo=",
      "endpoints": [
        "https://github.com/TheOverAchievingDev/T.O.A.D/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
